+      const lt = lineNums[i];
+      if (!lt.length) continue;
+      for (const tk of lt) if (!nameNums.has(tk.digits)) hasDataNumber = true;
+      if (resultNums.some((n) => numberMatches(n, lt))) resultColocated = true;
+    }
